<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FB">

    <!-- CARD UTAMA -->
    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- LOGO -->
            <ImageView
                android:src="@drawable/about"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="16dp"/>

            <!-- JUDUL -->
            <TextView
                android:text="About Us"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#3F51B5"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- DESKRIPSI -->
            <TextView
                android:text="Aplikasi Restaurant ini dibuat untuk memudahkan pemesanan makanan dan minuman secara digital. Dengan tampilan sederhana dan mudah digunakan."
                android:textSize="16sp"
                android:textColor="#555555"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- NAMA PEMBUAT -->
            <TextView
                android:text="Dibuat oleh: Shipa Amalia"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>