<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FB">

    <!-- HEADER -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Menu Minuman"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#009688"
        android:padding="24dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- LIST MINUMAN -->
    <LinearLayout
        android:id="@+id/layoutMinuman"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ITEM 1 -->
        <TextView
            android:id="@+id/minum1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🥤 Es Teh - Rp 5.000"
            android:textSize="22sp"
            android:textStyle="bold"
            android:padding="18dp"
            android:background="@android:color/white"
            android:layout_marginBottom="12dp"/>

        <!-- ITEM 2 -->
        <TextView
            android:id="@+id/minum2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="☕ Kopi - Rp 10.000"
            android:textSize="22sp"
            android:textStyle="bold"
            android:padding="18dp"
            android:background="@android:color/white"
            android:layout_marginBottom="12dp"/>

        <!-- ITEM 3 -->
        <TextView
            android:id="@+id/minum3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🥛 Susu - Rp 8.000"
            android:textSize="22sp"
            android:textStyle="bold"
            android:padding="18dp"
            android:background="@android:color/white"
            android:layout_marginBottom="12dp"/>

        <!-- ITEM 4 -->
        <TextView
            android:id="@+id/minum4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🍹 Jus Jeruk - Rp 12.000"
            android:textSize="22sp"
            android:textStyle="bold"
            android:padding="18dp"
            android:background="@android:color/white"
            android:layout_marginBottom="12dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>