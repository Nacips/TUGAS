<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FDFCFE">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="120dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:src="@drawable/logoresto"
            android:contentDescription="Logo Restoran"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RESTORAN KITA 🍴"
            android:textAlignment="center"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2D2D2D" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Menu Makanan 🍜"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#4A4A4A"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMakanan"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Menu Minuman 🥤"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#4A4A4A"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMinuman"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="#DDDDDD" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Ringkasan Pesanan"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#4A4A4A"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvOrder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="120dp"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            android:background="@android:color/white"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: Belum Dibayar"
                android:textStyle="bold"
                android:textColor="#F44336"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Total: Rp0"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#2D2D2D" />

            <EditText
                android:id="@+id/etBayar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Masukkan uang bayar"
                android:inputType="number"
                android:backgroundTint="#4CAF50" />

            <TextView
                android:id="@+id/tvKembalian"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Kembalian: Rp0"
                android:textStyle="bold"
                android:textColor="#388E3C" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnBayar"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Bayar 💸"
                android:textSize="14sp"
                android:backgroundTint="#4CAF50" />

            <Button
                android:id="@+id/btnCetak"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Cetak 🧾"
                android:textSize="14sp"
                android:backgroundTint="#2196F3" />
        </LinearLayout>

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:text="Pesanan Baru ✨"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="#F44336" />

    </LinearLayout>
</ScrollView>