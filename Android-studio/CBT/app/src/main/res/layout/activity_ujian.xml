<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutUjian"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="18dp"
    android:background="#F4F6F9">

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sisa Waktu: 10:00"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#D32F2F"
        android:gravity="end"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvNomorSoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Soal 1 dari 5"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0B132B"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvPertanyaan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pertanyaan soal"
        android:textSize="18sp"
        android:textColor="#222222"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:layout_marginBottom="18dp" />

    <RadioGroup
        android:id="@+id/rgPilihan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/rbA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A"
            android:textSize="16sp"
            android:padding="10dp" />

        <RadioButton
            android:id="@+id/rbB"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="B"
            android:textSize="16sp"
            android:padding="10dp" />

        <RadioButton
            android:id="@+id/rbC"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="C"
            android:textSize="16sp"
            android:padding="10dp" />

        <RadioButton
            android:id="@+id/rbD"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="D"
            android:textSize="16sp"
            android:padding="10dp" />

    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp">

        <Button
            android:id="@+id/btnSebelumnya"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sebelumnya"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnSelanjutnya"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Selanjutnya"
            android:textAllCaps="false"
            android:layout_marginStart="10dp" />

    </LinearLayout>

    <Button
        android:id="@+id/btnSelesai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selesai Ujian"
        android:textAllCaps="false"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        android:layout_marginTop="14dp" />

</LinearLayout>