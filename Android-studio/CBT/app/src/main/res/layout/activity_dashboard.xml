<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F4F6F9">

    <TextView
        android:id="@+id/tvPeserta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Peserta"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#0B132B"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Informasi Ujian"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1C77C3"
        android:layout_marginBottom="10dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mata Kuliah: Sistem Operasi&#10;Jumlah Soal: 5&#10;Waktu: 10 Menit&#10;Jenis Ujian: Pilihan Ganda"
        android:textSize="16sp"
        android:textColor="#333333"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:layout_marginBottom="30dp" />

    <Button
        android:id="@+id/btnMulai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mulai Ujian"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:backgroundTint="#0B132B"
        android:textColor="#FFFFFF" />

</LinearLayout>