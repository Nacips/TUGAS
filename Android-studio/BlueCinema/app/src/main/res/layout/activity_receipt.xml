<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🖨️ Cetak Struk"
            android:textColor="@color/white_text"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Simpan bukti pembayaran tiket dan snack Anda"
            android:textColor="@color/gray_text"
            android:textSize="14sp" />

        <!-- RECEIPT CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="22dp">

            <!-- STATUS BOX -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#102ECC71"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status Pembayaran"
                        android:textColor="@color/gray_text"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvReceiptStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="LUNAS ✅"
                        android:textColor="@color/green_success"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎟️"
                    android:textSize="34sp" />

            </LinearLayout>

            <!-- DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:background="#20FFFFFF" />

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧾 Detail Struk"
                android:textColor="@color/white_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- RECEIPT CONTENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="#12FFFFFF"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvReceiptContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="6dp"
                    android:text="Isi struk tampil di sini"
                    android:textColor="@color/gray_text"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- PRINT BUTTON -->
            <Button
                android:id="@+id/btnPrintNow"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_button_primary"
                android:elevation="4dp"
                android:text="🖨️ Cetak Struk Sekarang"
                android:textAllCaps="false"
                android:textColor="@color/white_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- HOME BUTTON -->
            <Button
                android:id="@+id/btnBackHome"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_primary"
                android:text="🏠 Kembali ke Home"
                android:textAllCaps="false"
                android:textColor="@color/white_text"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- FOOTER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:text="BlueCinema Self Service Ticketing"
            android:textColor="@color/gray_text"
            android:textSize="12sp" />

    </LinearLayout>

</ScrollView>