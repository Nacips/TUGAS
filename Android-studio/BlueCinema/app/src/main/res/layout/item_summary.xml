<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:background="#12FFFFFF"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <!-- LEFT CONTENT -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- ITEM NAME -->
        <TextView
            android:id="@+id/tvSummaryName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:text="🎬 Avengers Endgame"
            android:textColor="@color/white_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- ITEM INFO -->
        <TextView
            android:id="@+id/tvSummaryInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="1 x Rp50.000"
            android:textColor="@color/gray_text"
            android:textSize="13sp" />

        <!-- QTY CONTROL -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#18FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="4dp">

            <!-- MINUS -->
            <TextView
                android:id="@+id/btnMinus"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="#1E88E5"
                android:gravity="center"
                android:text="−"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- QTY -->
            <TextView
                android:id="@+id/tvQty"
                android:layout_width="42dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/white_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- PLUS -->
            <TextView
                android:id="@+id/btnPlus"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="2dp"
                android:background="#1E88E5"
                android:gravity="center"
                android:text="+"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- SUBTOTAL BOX -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#1E88E5"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subtotal"
            android:textColor="@android:color/white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvSummarySubtotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Rp50.000"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>